# RECOMMENDED: paste the entire contents of the downloaded service account
# JSON key file as one line, wrapped in single quotes. This avoids private-key
# escaping bugs entirely and is the only credential option you need.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n","client_email":"your-service-account@your-project.iam.gserviceaccount.com", ...}'

# LEGACY ALTERNATIVE: only used if GOOGLE_SERVICE_ACCOUNT_JSON is not set.
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXXXXXXXXXX\n-----END PRIVATE KEY-----\n"

# The ID of the Google Sheet (from its URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your-google-sheet-id
# Name of the tab/sheet inside the spreadsheet to use
GOOGLE_SHEET_NAME=Appointments

# Scheduling configuration
NUM_TELLERS=3
TELLER_NAMES=Teller 1,Teller 2,Teller 3
SLOT_MINUTES=5
BUSINESS_START=08:00
BUSINESS_END=17:00
# Set to "true" to skip Saturdays and Sundays when booking
SKIP_WEEKENDS=true
# Organisation name shown on the confirmation
ORG_NAME=Mount Kigali University Rwanda
